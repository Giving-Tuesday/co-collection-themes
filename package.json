{
  "name": "@giving-tuesday/co-collection-themes",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "version": "0.3.10",
  "author": "",
  "license": "ISC",
  "description": "Reusable React component + theme library for the co-embed app.",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": ">=18 <20",
    "react-dom": ">=18 <20",
    "react-icons": ">=4.0.0",
    "react-router-dom": ">=6.0.0"
  },
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && rollup -c rollup.config.ts --configPlugin typescript",
    "build:watch": "rollup -c rollup.config.ts --configPlugin typescript --watch",
    "dev": "npm run clean && npm run build:watch",
    "prepare": "npm run build",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write .",
    "release:patch": "npm version patch && npm publish --access public",
    "release:minor": "npm version minor && npm publish --access public",
    "release:major": "npm version major && npm publish --access public",
    "storybook": "storybook dev -p 6006",
    "build:stories": "storybook build",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.3.0",
    "@storybook/addon-links": "^10.2.8",
    "@storybook/react": "^10.2.8",
    "@storybook/react-vite": "^10.2.8",
    "@storybook/testing-library": "^0.2.2",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.2.3",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.2.14",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^4.0.0",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-storybook": "10.2.8",
    "postcss": "^8.4.47",
    "postcss-modules": "^6.0.0",
    "prettier": "^3.3.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "rollup": "^4.46.2",
    "rollup-plugin-dts": "^6.3.0",
    "rollup-plugin-postcss": "^4.0.2",
    "storybook": "^10.2.8",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^5.3.0"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "axios": "^1.12.2",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "leaflet": "^1.9.4",
    "protomaps-leaflet": "^5.1.0",
    "react-leaflet": "^5.0.0",
    "remark-html": "^16.0.1",
    "remark-parse": "^11.0.0",
    "topojson-client": "^3.1.0",
    "unified": "^11.0.5"
  }
}
